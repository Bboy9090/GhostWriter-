# Docker Compose / Local Development
# Copy to .env and fill in values. Never commit .env.

# PostgreSQL (vault-db)
POSTGRES_USER=ghostwriter_user
POSTGRES_PASSWORD=change_me_secure_password
POSTGRES_DB=ghostwriter_vault

# Backend API (ghost-api)
JWT_SECRET=change_me_32_char_minimum_secret_key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Frontend (ghostwriter-frontend) - API URL for local docker-compose
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws

# Optional: enable cloud vault semantic search in the main UI (POST /vault/search)
# Must match a user_id that exists in your server vault.
# VITE_GHOSTWRITER_API_URL=http://localhost:8080
VITE_GHOSTWRITER_USER_ID=
