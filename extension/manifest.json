{
  "manifest_version": 3,
  "name": "GhostWriter Portal",
  "version": "1.0.0",
  "description": "Side-panel portal for screen text capture. No focus switching – scroll the page while the portal stays visible.",
  "permissions": ["sidePanel", "activeTab", "storage", "scripting"],
  "action": {
    "default_title": "Open GhostWriter Portal"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+G",
        "mac": "Command+Shift+G"
      },
      "description": "Open GhostWriter Portal"
    }
  }
}
