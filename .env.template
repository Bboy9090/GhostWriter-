# GhostWriter Frontend Environment Variables
# Copy this file to .env.local for local development

# API Configuration
VITE_API_URL=https://ghostwriter-api.fly.dev
VITE_WS_URL=ws://localhost:8080/ws

# Optional: Analytics
# VITE_ENABLE_ANALYTICS=false

# Optional: Feature Flags
# VITE_ENABLE_EXPERIMENTAL_FEATURES=false

# Note: For production deployment on Vercel:
# 1. Go to your Vercel project settings
# 2. Navigate to "Environment Variables"
# 3. Add these variables with production values:
#    - VITE_API_URL=https://your-production-api.com
#    - VITE_WS_URL=wss://your-production-api.com/ws
