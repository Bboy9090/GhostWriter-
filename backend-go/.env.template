# Database Configuration
# Option A: MongoDB (takes precedence when set)
# MONGODB_URI=mongodb://user:password@host:27017/ghostwriter?authSource=admin
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ghostwriter

# Option B: PostgreSQL (fallback when MONGODB_URI is not set)
DB_URL=postgres://bobby_admin:bronx_password@vault-db:5432/ghostwriter_vault?sslmode=disable

# Post TTL (MongoDB only)
# Number of days after which portal entries are automatically deleted.
# Set to 0 or leave unset to keep entries forever (recommended default).
# POST_TTL_DAYS=0

# Redis Configuration
REDIS_URL=ghost-stream:6379

# Server Configuration
PORT=8080

# JWT Secret (for future authentication)
JWT_SECRET=your_jwt_secret_key_here

# OpenAI API Key (for embeddings)
OPENAI_API_KEY=sk-your-openai-api-key-here

# APNS Configuration (Apple Push Notification Service)
# Authentication mode: "certificate" or "token"
APNS_AUTH_MODE=token

# For certificate-based authentication
APNS_CERT_PATH=/path/to/your/apns_certificate.p12

# For token-based authentication (recommended)
APNS_KEY_PATH=/path/to/your/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX

# APNS Settings
APNS_TOPIC=com.ghostwriter.app
APNS_PRODUCTION=false
